{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "mommas-bakeshop",
    "version": "0.1.0",
    "description": "Momma's Bakeshop desktop and web application.",
    "author": "Momma's Bakeshop",
    "private": true,
    "type": "module",
    "main": "desktop/main.mjs",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "desktop:bootstrap": "php artisan desktop:bootstrap --force",
        "desktop:dev": "electron desktop/main.mjs",
        "desktop:dir": "npm run build && node desktop/package.mjs dir",
        "desktop:package": "npm run build && node desktop/package.mjs package"
    },
    "devDependencies": {
        "@headlessui/react": "^2.0.0",
        "@inertiajs/react": "^2.0.0",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-react": "^4.2.0",
        "axios": "^1.11.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "concurrently": "^9.0.1",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "laravel-vite-plugin": "^2.0.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwind-merge": "^3.0.1",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tooltip": "^1.2.8",
        "html2canvas": "^1.4.1",
        "jspdf": "^4.2.0",
        "jspdf-autotable": "^5.0.7",
        "lucide-react": "^0.577.0",
        "recharts": "^3.7.0"
    },
    "build": {
        "appId": "com.mommasbakeshop.desktop",
        "productName": "Momma's Bakeshop",
        "asar": false,
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "app/**/*",
            "artisan",
            "bootstrap/**/*",
            "composer.json",
            "composer.lock",
            ".env.example",
            "config/**/*",
            "database/**/*",
            "desktop/**/*",
            "!desktop/runtime/**",
            "package.json",
            "public/**/*",
            "resources/views/**/*",
            "routes/**/*",
            "storage/framework/views/**/*",
            "vendor/**/*"
        ],
        "extraResources": [
            {
                "from": "desktop/runtime",
                "to": "runtime"
            }
        ],
        "extraMetadata": {
            "main": "desktop/main.mjs"
        }
    }
}
